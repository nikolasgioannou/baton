{
  "name": "baton",
  "version": "0.0.0",
  "description": "Share Claude Code conversations with others",
  "type": "module",
  "bin": {
    "baton": "./bin/baton"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/baton",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "bin",
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nikolasgioannou/baton.git"
  },
  "homepage": "https://github.com/nikolasgioannou/baton",
  "bugs": {
    "url": "https://github.com/nikolasgioannou/baton/issues"
  },
  "author": "Nikolas Ioannou",
  "license": "MIT",
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "conversation",
    "share"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.12",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
