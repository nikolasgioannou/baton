{
  "name": "baton",
  "version": "0.2.0",
  "description": "Share Claude Code conversations with others",
  "type": "module",
  "bin": {
    "baton": "./bin/baton"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/baton",
    "build:darwin-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile dist/baton-darwin-arm64",
    "build:darwin-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile dist/baton-darwin-x64",
    "build:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile dist/baton-linux-x64",
    "build:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile dist/baton-linux-arm64",
    "build:all": "bun run build:darwin-arm64 && bun run build:darwin-x64 && bun run build:linux-x64 && bun run build:linux-arm64",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major",
    "prepare": "lefthook install"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "bin",
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nikolasgioannou/baton.git"
  },
  "homepage": "https://github.com/nikolasgioannou/baton",
  "bugs": {
    "url": "https://github.com/nikolasgioannou/baton/issues"
  },
  "author": "Nikolas Ioannou",
  "license": "MIT",
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "conversation",
    "share"
  ],
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.12",
    "@types/tar-stream": "^3.1.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "tar-stream": "^3.1.8"
  }
}
